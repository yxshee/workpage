\n=== globals.css ===
@import "tailwindcss";

@theme {
  --color-primary-blue: #0008ff;
  --color-bg-white: #fcfcfc;
  --color-text-secondary: #999999;
  --color-border-subtle: #e5e5e5;

  --font-haas: 'Neue Haas Grotesk Display Pro', 'Inter', sans-serif;
}

@layer base {
  body {
    background-color: var(--color-bg-white);
    color: black;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    font-family: var(--font-haas);
  }
}

@layer components {
  .vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at center, transparent 0%, rgba(0, 8, 255, 0.03) 100%);
    z-index: 50;
  }

  .nav-link {
    @apply text-sm font-medium transition-colors hover:text-primary-blue;
  }
}

/* Custom 3D Slider Styles */
.slider-container {
  perspective: 1200px;
  transform-style: preserve-3d;
}

.slider-item {
  transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}